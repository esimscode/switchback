// Switchback — source-of-truth schema (PRD §12)
// Neon Postgres · Prisma 7 (prisma-client generator, driver adapters)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum ContentStatus {
  DRAFT
  READY
  PUBLISHED
}

enum FitClassification {
  STRONG_FIT
  STRETCH_FIT
  BRIDGE_ROLE
  NOT_WORTH_IT
}

enum ApplicationStatus {
  SAVED
  APPLIED
  FOLLOW_UP_NEEDED
  INTERVIEWING
  REJECTED
  OFFER
  ACCEPTED
  PASSED
}

// Honest project labels — a core credibility rule (PRD §6, §16)
enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  PROTOTYPE
  IMPLEMENTED
  TESTED
  DEPLOYED
  COMPLETED
}

enum ReflectionType {
  WEEKLY_CHECKIN
  DECISION
  BLOCKER
  OPPORTUNITY
  PROJECT_NOTE
  INTERVIEW_REFLECTION
  APPLICATION_REFLECTION
}

enum MemoryCategory {
  POSITIONING
  PREFERENCE
  CONSTRAINT
  PROJECT
  RESUME_RULE
  JOB_SEARCH_RULE
  PORTFOLIO_RULE
  INTERVIEW_RULE
}

enum JobLeadStatus {
  NEW
  REVIEWED
  ANALYZING // background full analysis in flight; promoted by the agent when done
  DISMISSED
  PROMOTED
}

enum DecisionType {
  APPLY
  PASS
  TAILOR_RESUME
  PRIORITIZE_PROJECT
  ACCEPT_OFFER
  REJECT_OFFER
  PROJECT_FOCUS
}

// ---------- Models ----------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  location  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  careerProfile      CareerProfile?
  resumeVersions     ResumeVersion[]
  jobLeads           JobLead[]
  jobAnalyses        JobAnalysis[]
  applications       Application[]
  projects           Project[]
  caseStudies        CaseStudy[]
  interviewStories   InterviewStory[]
  careerReflections  CareerReflection[]
  careerMemories     CareerMemory[]
  strategicDecisions StrategicDecision[]
  agentOutputs       AgentOutput[]
  notifications      Notification[]

  @@map("users")
}

model CareerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  primaryHeadline  String   @map("primary_headline")
  corePositioning  String   @map("core_positioning")
  coreStory        String   @map("core_story")
  portfolioTagline String?  @map("portfolio_tagline")
  linkedinHeadline String?  @map("linkedin_headline")
  targetRoles      Json     @default("[]") @map("target_roles")
  bridgeRoles      Json     @default("[]") @map("bridge_roles")
  skills           Json     @default("[]")
  credibilityRules Json     @default("[]") @map("credibility_rules")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("career_profiles")
}

model ResumeVersion {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  name       String
  // Free-form role family this version targets (e.g. "Master",
  // "Platform / DevSecOps", "Growth Marketing") — set per user during
  // onboarding rather than baked into the schema.
  roleFamily String  @map("role_family")
  content    String?
  status    ContentStatus     @default(DRAFT)
  sourceUrl String?           @map("source_url")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobAnalyses  JobAnalysis[]
  applications Application[]

  @@unique([userId, roleFamily])
  @@map("resume_versions")
}

model JobAnalysis {
  id                         String             @id @default(cuid())
  userId                     String             @map("user_id")
  company                    String
  roleTitle                  String             @map("role_title")
  jobDescription             String             @map("job_description")
  sourceUrl                  String?            @map("source_url")
  salaryRange                String?            @map("salary_range")
  location                   String?
  fitClassification          FitClassification? @map("fit_classification")
  recommendedResumeVersionId String?            @map("recommended_resume_version_id")
  skillsToEmphasize          Json               @default("[]") @map("skills_to_emphasize")
  gaps                       Json               @default("[]")
  tailoredSummary            String?            @map("tailored_summary")
  interviewTalkingPoints     Json               @default("[]") @map("interview_talking_points")
  recommendation             String?
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendedResumeVersion ResumeVersion? @relation(fields: [recommendedResumeVersionId], references: [id], onDelete: SetNull)
  applications             Application[]
  agentOutputs             AgentOutput[]
  jobLead                  JobLead?

  @@map("job_analyses")
}

model Application {
  id                String             @id @default(cuid())
  userId            String             @map("user_id")
  company           String
  roleTitle         String             @map("role_title")
  roleFamily        String?            @map("role_family")
  resumeVersionId   String?            @map("resume_version_id")
  jobAnalysisId     String?            @map("job_analysis_id")
  dateApplied       DateTime?          @map("date_applied")
  source            String?
  contact           String?
  status            ApplicationStatus  @default(SAVED)
  followUpDate      DateTime?          @map("follow_up_date")
  salaryRange       String?            @map("salary_range")
  link              String?
  notes             String?
  fitClassification FitClassification? @map("fit_classification")
  decisionReasoning String?            @map("decision_reasoning")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeVersion    ResumeVersion?     @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)
  jobAnalysis      JobAnalysis?       @relation(fields: [jobAnalysisId], references: [id], onDelete: SetNull)
  interviewStories InterviewStory[]
  reflections      CareerReflection[]
  agentOutputs     AgentOutput[]

  @@map("applications")
}

model Project {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  name          String
  slug          String        @unique
  status        ProjectStatus @default(PLANNED)
  summary       String?
  problem       String?
  solution      String?
  stack         Json          @default("[]")
  role          String?
  careerSignal  String?       @map("career_signal")
  githubUrl     String?       @map("github_url")
  portfolioUrl  String?       @map("portfolio_url")
  nextMilestone String?       @map("next_milestone")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseStudies      CaseStudy[]
  interviewStories InterviewStory[]
  reflections      CareerReflection[]
  agentOutputs     AgentOutput[]

  @@map("projects")
}

model CaseStudy {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  projectId    String        @map("project_id")
  title        String
  status       ContentStatus @default(DRAFT)
  problem      String?
  solution     String?
  stack        String?
  architecture String?
  challenges   String?
  outcome      String?
  nextSteps    String?       @map("next_steps")
  careerSignal String?       @map("career_signal")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("case_studies")
}

model InterviewStory {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  projectId          String?  @map("project_id")
  applicationId      String?  @map("application_id")
  title              String
  situation          String
  task               String
  action             String
  result             String
  skillsDemonstrated Json     @default("[]") @map("skills_demonstrated")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@map("interview_stories")
}

model CareerReflection {
  id                   String         @id @default(cuid())
  userId               String         @map("user_id")
  reflectionType       ReflectionType @map("reflection_type")
  title                String
  body                 String
  mood                 String?
  relatedProjectId     String?        @map("related_project_id")
  relatedApplicationId String?        @map("related_application_id")
  createdAt            DateTime       @default(now()) @map("created_at")

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedProject     Project?     @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  relatedApplication Application? @relation(fields: [relatedApplicationId], references: [id], onDelete: SetNull)

  @@map("career_reflections")
}

model CareerMemory {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  key        String
  value      String
  category   MemoryCategory
  source     String?
  confidence String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("career_memories")
}

model StrategicDecision {
  id                String       @id @default(cuid())
  userId            String       @map("user_id")
  decisionType      DecisionType @map("decision_type")
  context           String
  optionsConsidered Json         @default("[]") @map("options_considered")
  decision          String
  reasoning         String?
  tradeoffs         String?
  nextAction        String?      @map("next_action")
  createdAt         DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("strategic_decisions")
}

model AgentOutput {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  outputType           String   @map("output_type")
  title                String
  content              String
  relatedProjectId     String?  @map("related_project_id")
  relatedApplicationId String?  @map("related_application_id")
  relatedJobAnalysisId String?  @map("related_job_analysis_id")
  createdAt            DateTime @default(now()) @map("created_at")

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedProject     Project?     @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  relatedApplication Application? @relation(fields: [relatedApplicationId], references: [id], onDelete: SetNull)
  relatedJobAnalysis JobAnalysis? @relation(fields: [relatedJobAnalysisId], references: [id], onDelete: SetNull)

  @@map("agent_outputs")
}

// Sourced job postings awaiting triage. Leads are ephemeral by design:
// the hygiene sweep hard-deletes non-promoted leads once the posting has
// expired or stopped appearing at its source (lastSeenAt goes stale).
// DISMISSED leads are kept while the posting is live so re-fetches don't
// resurrect them as NEW. Promotion hands off to JobAnalysis, the durable record.
model JobLead {
  id            String            @id @default(cuid())
  userId        String            @map("user_id")
  source        String // "adzuna" | "greenhouse" | "lever" | "ashby" | "manual"
  externalId    String?           @map("external_id")
  // Normalized source+externalId (or canonical URL) hash; upserts key on this.
  dedupeKey     String            @map("dedupe_key")
  company       String
  roleTitle     String            @map("role_title")
  location      String?
  salaryRange   String?           @map("salary_range")
  url           String
  description   String? // snippet or full text, source-dependent
  status        JobLeadStatus     @default(NEW)
  // Cheap one-pass triage against the career profile; full analysis only on promotion.
  triageFit     FitClassification? @map("triage_fit")
  triageSummary String?           @map("triage_summary")
  postedAt      DateTime?         @map("posted_at")
  expiresAt     DateTime?         @map("expires_at")
  lastSeenAt    DateTime          @default(now()) @map("last_seen_at")
  metadata      Json              @default("{}")
  promotedJobAnalysisId String?   @unique @map("promoted_job_analysis_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  promotedJobAnalysis JobAnalysis? @relation(fields: [promotedJobAnalysisId], references: [id], onDelete: SetNull)

  @@unique([userId, dedupeKey])
  @@index([userId, status])
  @@index([userId, lastSeenAt])
  @@map("job_leads")
}

// In-app notifications: background work surfacing to the user (new triaged
// leads, completed background analyses). Written by agent tools and server
// actions; the bell in the page header reads them.
model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String // "leads_reviewed" | "analysis_ready"
  title     String
  href      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// Landing-page waitlist: people interested in a hosted/cloud Switchback.
model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_signups")
}
