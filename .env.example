# Neon Postgres (pooled URL for runtime, direct URL for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST/neondb?sslmode=require"

# Vercel AI Gateway — powers the Eve strategist agent
AI_GATEWAY_API_KEY=""

# Neon Auth (provision from the Neon console: Project → Branch → Auth)
NEON_AUTH_BASE_URL="https://YOUR-ENDPOINT.neonauth.REGION.aws.neon.tech/neondb/auth"
NEON_AUTH_COOKIE_SECRET=""  # openssl rand -base64 32

# Comma-separated emails allowed to sign up / use the workspace (optional; unset = open)
AUTH_ALLOWED_EMAILS=""
